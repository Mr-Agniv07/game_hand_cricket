# PostgreSQL connection string for the database.
# Local dev: your own Postgres, or a free cloud DB (Neon/Supabase).
# Production (Render): set this in the service's Environment settings.
#
# Neon: use the POOLED connection string (host contains "-pooler"), and keep
# sslmode=require. Example shape:
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/cricflick?sslmode=require"
DATABASE_URL="postgresql://user:password@localhost:5432/cricflick?schema=public"

# Server port (Render sets this automatically; defaults to 3001 locally).
# PORT=3001
